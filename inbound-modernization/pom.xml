<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.maersk.wms</groupId>
        <artifactId>wms-transformation</artifactId>
        <version>1.0.0-SNAPSHOT</version>
    </parent>

    <artifactId>inbound-modernization</artifactId>
    <packaging>pom</packaging>
    <name>Inbound Modernization - Inbound Bounded Context</name>
    <description>
        Inbound Bounded Context with 3 Subdomains:

        1. RECEIVING SUBDOMAIN (inbound-service + inbound-operations-service)
           - ASN (Advance Ship Notice) processing
           - Purchase Order management
           - Receipt creation and management
           - GRN (Goods Receipt Note) processing

        2. RETURNS SUBDOMAIN
           - RMA (Return Merchandise Authorization) processing
           - Return inspection workflows
           - Disposition management (restock, refurbish, scrap)
           - Refund/credit processing

        3. PUTAWAY SUBDOMAIN (putaway-service)
           - Putaway strategy execution
           - Location allocation algorithms
           - Cross-docking support
           - Task management integration

        Organized following DDD principles with:
        - Shared Kernel for cross-subdomain types
        - Anti-Corruption Layer for subdomain communication
        - Future-proof for microservice extraction
    </description>

    <modules>
        <!-- Shared Kernel (must be first - no dependencies on other inbound modules) -->
        <module>inbound-shared-kernel</module>

        <!-- Core Domain Modules -->
        <module>inbound-domain</module>
        <module>inbound-infrastructure</module>

        <!-- Anti-Corruption Layer (subdomain communication) -->
        <module>inbound-acl</module>

        <!-- Business Logic Modules -->
        <module>inbound-kafka</module>
        <module>inbound-rules</module>
        <module>inbound-variation</module>
        <module>inbound-service-core</module>
        <module>inbound-activity</module>
        <module>inbound-workflow</module>
        <module>inbound-legacy-bridge</module>
        <module>inbound-plugin</module>

        <!-- API & Config -->
        <module>inbound-api</module>
        <module>inbound-config</module>

        <!-- Testing -->
        <module>inbound-test</module>
    </modules>

    <properties>
        <java.version>17</java.version>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <temporal.version>1.22.3</temporal.version>
        <drools.version>9.44.0.Final</drools.version>
        <mapstruct.version>1.5.5.Final</mapstruct.version>
        <springdoc.version>2.5.0</springdoc.version>
    </properties>

